# Copy this file to `.env` in this folder (`backend/.env`).
# Values load via pydantic-settings (see `app/config.py`).

# Application
APP_ENV=development
# Comma-separated browser origins allowed to call the API (no spaces). Add your Netlify site
# after first deploy, e.g. https://your-site.netlify.app — set this in Render/host env, not in Git.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080

# SQLite database file (resolved under backend/data/ — see app/db/session.py)
DATABASE_URL=sqlite:///./data/app.db

# Migrations (run from `backend/`):  alembic revision --autogenerate -m "describe_change"
#                                   alembic upgrade head

# Maximum Excel upload size in bytes (default ~10 MiB)
MAX_UPLOAD_BYTES=10485760

# --- Column-mapping LLM (optional) ---
# Prefer OpenAI when deploying (no local model download). If OPENAI_API_KEY is set, it is used
# before Ollama. Never commit real keys; use platform secrets in production.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Local Ollama (only if OPENAI_API_KEY is empty)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:0.5b
OLLAMA_ENABLED=false
